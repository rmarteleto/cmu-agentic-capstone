# ============ LLM backend ============
# Choose "openai" or "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ============ Embeddings ============
EMBEDDING_MODEL=text-embedding-3-large

# ============ Vector DB (Chroma) ============
CHROMA_PERSIST_DIR=./data/chroma
SOP_COLLECTION=sop_corpus
SIG_COLLECTION=sig_history

# ============ Azure Blob Storage (SOP download) ============
# Pick one auth method:
AZURE_STORAGE_CONNECTION_STRING=   # full connection string (easiest)
# -- OR --
AZURE_STORAGE_ACCOUNT_NAME=        # storage account name
AZURE_STORAGE_ACCOUNT_KEY=         # storage account key
AZURE_BLOB_CONTAINER=              # container holding the sop/ blobs

# ============ Reasoning bounds (Tree of Thoughts) ============
BEAM_WIDTH=2            # W
MAX_DEPTH=3             # D
BRANCH_FACTOR=5         # B  (top-K retrieved chunks per question)
CHUNK_MAX_WORDS=1000    # words per SOP chunk
CHUNK_OVERLAP_WORDS=200 # overlap between consecutive windows
RELEVANCE_THRESHOLD=0.45
CRITIC_MIN_SCORE=3      # absolute prune threshold on scope completeness

# ============ Hybrid search blend ============
SEMANTIC_WEIGHT=0.6
KEYWORD_WEIGHT=0.4
ENABLE_RERANKER=true   # cross-encoder rerank (degrades gracefully if unavailable)

# ============ M6 input guardrails ============
ENABLE_INPUT_GUARD=true
MIN_QUESTION_CHARS=8
MAX_QUESTION_CHARS=4000

# ============ Serving / runtime ============
MAX_WORKERS=4
SIG_API_KEY=            # REST x-api-key; empty = open (dev only)
MCP_TRANSPORT=stdio     # stdio | streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8000
